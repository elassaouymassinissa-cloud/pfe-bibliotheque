{
  "liveServer.settings.port": 5501,
  "javascript.suggest.includeCompletionsFromAllFiles": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "files.autoSave": "onFocusChange",
  "editor.formatOnSave": true,
  "javascript.format.enable": false,
  "workbench.iconTheme": "material-icon-theme",
  "javascript.validate.enable": false,
  "eslint.enable": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  "codesnap.backgroundColor": "#282c34",
"codesnap.roundedCorners": true,
"codesnap.showWindowControls": true,
"codesnap.shadow": true,
"codesnap.padding": 32,
"codesnap.target": "clipboard",

"code-runner.executorMap": {
    "php": "php",                   // PHP
    "javascript": "node",           // JavaScript avec Node.js
    "python": "python",             // Python
    "python3": "python3",           // Python3
    "java": "java",                 // Java
    "html": "start",                // HTML (sur Windows, ouvre dans un navigateur)
    "css": "start",                 // CSS (sur Windows, ouvre dans un navigateur
    "kotlin": "kotlin"          // Kotlin  
},


  
}


